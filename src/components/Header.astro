---
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav class="header-nav">
    <div class="nav-left">
      <div class="logo-wrapper">
        <a href="/" aria-label="Home">
          <img 
            src="/favicon.svg"   <!-- 用你有的 SVG，清晰优先 -->
            alt="Kingsley Qi Logo"
            width="56"
            height="56"
          />
        </a>
      </div>

      <span class="nav-divider"></span>

      <div class="internal-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>
    </div>
  </nav>
</header>

<style>
  /* 原有样式保留，只简化并加关键保护 */
  header {
    margin: 0;
    padding: 0;
    background: #ffffff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    height: 70px;
    display: flex;
    align-items: center;
  }

  .header-nav {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 100%;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    min-width: 60px;     /* 强制宽度不塌 */
    height: 56px;
    min-height: 56px;    /* 强制高度不塌 */
  }

  .logo-wrapper img {
    display: block;
    width: 56px;
    height: 56px;
    object-fit: contain; /* 保持比例 */
  }

  /* 其他样式保持原样 */
  .nav-divider {
    width: 1px;
    height: 24px;
    background: #eee;
  }

  .internal-links {
    display: flex;
    align-items: center;
    height: 100%;
  }

  .internal-links :global(a) {
    padding: 0 1rem;
    height: 70px;
    display: flex;
    align-items: center;
    color: #444;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    position: relative;
    transition: color 0.2s ease;
  }

  .internal-links :global(a:hover) {
    color: #000;
  }

  .internal-links :global(a.active::after),
  .internal-links :global(a:hover::after) {
    content: '';
    position: absolute;
    bottom: 0;
    left: 15%;
    width: 70%;
    height: 3px;
    background: #333;
    border-radius: 2px 2px 0 0;
  }

  .internal-links :global(a.active) {
    color: #000;
    font-weight: 600;
  }
</style>